# RAG Chatbot — Environment Configuration Template
# Copy this file to .env and fill in your API keys
# The app works without these keys — they enable additional backends

# ═══════════════════════════════════════════════════════════════════════════
# LLM BACKENDS
# ═══════════════════════════════════════════════════════════════════════════

# GROQ API — Fast inference (Recommended if you have an API key)
# Model: llama-3.1-8b-instant
# Get free API key at: https://console.groq.com/keys
# Without this key, the app falls back to HuggingFace or extractive mode
GROQ_API_KEY=

# HuggingFace Inference API — Free alternative
# Model: mistralai/Mistral-7B-Instruct-v0.2
# Get token at: https://huggingface.co/settings/tokens
# Leave empty to use public access (may have rate limits)
HUGGINGFACE_API_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: Advanced Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Tesseract OCR path (if installed in non-standard location)
# On Windows: C:\Program Files\Tesseract-OCR
# On Linux: /usr/bin/tesseract
# TESSDATA_PREFIX=/usr/share/tesseract-ocr-4.00/tessdata

# ═══════════════════════════════════════════════════════════════════════════
# BACKEND PRIORITY (automatic fallback)
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. GROQ_API_KEY set → Uses Groq (fastest, ~1-3s per answer)
# 2. GROQ not available → Uses HuggingFace (free, ~2-10s, may cold-start)
# 3. Both unavailable → Extractive fallback (instant, returns top chunk)
#
# ═══════════════════════════════════════════════════════════════════════════
